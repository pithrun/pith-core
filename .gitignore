# ============================================================
# PUBLIC REPO .gitignore — pith-core
# ============================================================

# --- Secrets ---
.env
.env.local
.env.*.local

# --- Pith data (personal, never commit) ---
data/*.db
data/*.db-shm
data/*.db-wal
data/concepts/
data/knowledge_areas/
data/associations/
data/index/
data/self_model/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.so
*.egg-info/
dist/
build/
venv/
.venv/

# --- Node ---
node_modules/
npm-debug.log
package-lock.json

# --- SQLite transient ---
*.db-shm
*.db-wal

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*~
Thumbs.db

# --- Logs ---
logs/
*.log
